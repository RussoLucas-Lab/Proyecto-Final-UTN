      "type": "n8n-nodes-base.merge",
      "typeVersion": 2,
      "position": [480, 320]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT c.id, c.area, c.creado_en, cl.nombre, cl.dni\nFROM caso c\nJOIN cliente cl ON c.cliente_id = cl.id\nORDER BY c.creado_en DESC",
        "additionalFields": {}
      },
      "id": "postgres-extraer-datos",
      "name": "Extraer casos y clientes",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2,
      "position": [680, 320],
      "credentials": {
        "postgres": {
          "id": "POSTGRES_CREDENTIAL_ID",
          "name": "Iuris — PostgreSQL"
        }
      }
    },
    {
      "parameters": {
        "operation": "toFile",
        "fileFormat": "xlsx",
        "options": {}
      },
      "id": "spreadsheet-file",
      "name": "Generar Excel",
      "type": "n8n-nodes-base.spreadsheetFile",
      "typeVersion": 2,
      "position": [880, 320]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_URL }}/api/v1/internal/storage/presigned-upload",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "filename",
              "value": "=backup_{{ $now.format('yyyy-MM-dd') }}.xlsx"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-Secret",
              "value": "={{ $env.N8N_INTERNAL_SECRET }}"
            }
          ]
        },
        "options": {}
      },
      "id": "get-presigned-url",
      "name": "Obtener URL prefirmada",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1080, 320]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "={{ $json.upload_url }}",
        "sendBody": true,
        "contentType": "binaryData",
        "inputDataFieldName": "data",
        "options": {}
      },
      "id": "upload-excel-storage",
      "name": "Subir Excel a Storage",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1280, 320]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/api/v1/internal/backups",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "tipo",
              "value": "={{ $('Merge').first().json.tipo }}"
            },
            {
              "name": "estado",
              "value": "OK"
            },
            {
              "name": "ubicacion",
              "value": "=backup_{{ $now.format('yyyy-MM-dd') }}.xlsx"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-Secret",
              "value": "={{ $env.N8N_INTERNAL_SECRET }}"
            }
          ]
        },
        "options": {}
      },
      "id": "registrar-backup-ok",
      "name": "Registrar backup OK",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1480, 320]
    },
    {
      "parameters": {
