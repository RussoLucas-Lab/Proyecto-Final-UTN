              "value": "={{ $('Merge').first().json.tipo }}"
            },
            {
              "name": "estado",
              "value": "ERROR"
            },
            {
              "name": "ubicacion",
              "value": null
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Internal-Secret",
              "value": "={{ $env.N8N_INTERNAL_SECRET }}"
            }
          ]
        },
        "options": {}
      },
      "id": "registrar-backup-error",
      "name": "Registrar backup ERROR",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1480, 500]
    }
