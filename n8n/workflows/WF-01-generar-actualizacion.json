    {
      "parameters": {
        "text": "=Generá una actualización para el caso con ID {{ $json.body.caso_id }}. Usá la herramienta obtener_contexto_caso con {\"caso_id\": {{ $json.body.caso_id }}} para obtener los datos.",
        "options": {
          "systemMessage": "=\"Sos un asistente jurídico del Estudio Iuris (Argentina). \nTu tarea es redactar una actualización clara y empática para el cliente sobre el avance de su caso.\\n\\nUSA la herramienta 'obtener_contexto_caso' para obtener el contexto del caso antes de redactar.\\n\\nREGLAS:\\n- Redactá en español rioplatense formal pero accesible.\\n- Basate SOLO en los datos devueltos por la herramienta; NO inventes datos ni plazos.\\n- Si hay novedades, mencionálas brevemente.\\n- Si no hay novedades recientes, redactá un mensaje genérico que informe la etapa actual.\\n- El mensaje debe ser breve (3-5 oraciones), sin jerga legal innecesaria.\\n- NO incluyas instrucciones al abogado ni meta-comentarios.\\n- La respuesta debe ser SOLO el texto del mensaje al cliente (sin encabezado JSON ni explicaciones).\"",
          "returnIntermediateSteps": false
        },
        "credentials": {
          "openAiApi": {
            "id": "IA_API_KEY",
            "name": "OpenAI — Iuris IA"
          }
        }
      },
      "id": "ai-agent",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1,
      "position": [
        624,
        304
      ]
    },
    {
      "parameters": {
        "toolDescription": "Obtiene toda la información de un caso jurídico a partir de su ID, incluyendo datos del cliente, estado, actuaciones, documentos y contexto necesario para generar actualizaciones.",
        "url": "={{ $env.BACKEND_URL }}/api/v1/internal/casos/{{ $('Webhook Trigger').first().json.body.caso_id }}/contexto",
        "sendHeaders": true,
        "parametersHeaders": {
          "values": [
            {
              "name": "x-internal-secret",
              "valueProvider": "fieldValue",
              "value": "={{ $('Set Internal Secret').first().json.internal_secret }}"
