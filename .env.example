# ══════════════════════════════════════════════════════════════════
#  Iuris — Variables de entorno
#  Copiá este archivo a .env y completá los valores reales.
#  NUNCA commitear .env (está en .gitignore).
#  ADR-0004 · §1 de docs/07-seguridad-y-despliegue/
# ══════════════════════════════════════════════════════════════════


# ── Base de datos (ACTIVAS — se consumen en este change) ──────────

# Usuario de la base de datos PostgreSQL
DB_USER=iuris

# Contraseña de la base de datos PostgreSQL
DB_PASSWORD=changeme

# URL de conexión completa (usada por el backend FastAPI / SQLAlchemy)
# Formato: postgresql://<user>:<password>@<host>:<port>/<dbname>
# En Docker el host es "db" (nombre del servicio en el compose)
DATABASE_URL=postgresql://iuris:changeme@db:5432/iuris

# Variables específicas de la imagen docker postgres:16
POSTGRES_USER=iuris
POSTGRES_PASSWORD=changeme
POSTGRES_DB=iuris


# ── Logging (ACTIVA) ──────────────────────────────────────────────

# Nivel de log del backend (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO


# ══════════════════════════════════════════════════════════════════
#  PLACEHOLDERS — changes futuros (aún no se consumen en el backend)
# ══════════════════════════════════════════════════════════════════

# ── Auth / Seguridad (change: auth) ──────────────────────────────

# Secreto para firmar los JWT (access + refresh). Mínimo 32 bytes aleatorios.
# Generar con: openssl rand -hex 32
# JWT_SECRET=REEMPLAZAR_CON_SECRETO_REAL

# Algoritmo JWT (HS256 recomendado)
# JWT_ALGORITHM=HS256

# Duración del access token en minutos (por defecto 15)
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Duración del refresh token en días (por defecto 7)
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7


# ── Cloudflare R2 (change: documentos) ───────────────────────────

# ID de cuenta de Cloudflare
# R2_ACCOUNT_ID=REEMPLAZAR

# Access Key ID de R2 (S3-compatible)
# R2_ACCESS_KEY_ID=REEMPLAZAR

# Secret Access Key de R2
# R2_SECRET_ACCESS_KEY=REEMPLAZAR

# Nombre del bucket R2
# R2_BUCKET_NAME=iuris-documentos

# Endpoint público del bucket (para presigned URLs)
# R2_PUBLIC_URL=https://<bucket>.<account>.r2.cloudflarestorage.com


# ── n8n / Webhooks (change: comunicaciones) ───────────────────────

# URL base del servidor n8n (usado por el backend para disparar webhooks)
# N8N_WEBHOOK_URL=http://n8n:5678/webhook

# Secreto compartido para autenticar al backend ante n8n
# N8N_SHARED_SECRET=REEMPLAZAR_CON_SECRETO_REAL


# ── Rate Limiting (change: seguridad) ─────────────────────────────

# Límite de requests al endpoint de login (intentos por minuto)
# RATE_LIMIT_LOGIN=5

# Límite general de la API (requests por minuto por IP)
# RATE_LIMIT_API=100
