# ══════════════════════════════════════════════════════════════════
#  Iuris — Variables de entorno
#  Copiá este archivo a .env y completá los valores reales.
#  NUNCA commitear .env (está en .gitignore).
#  ADR-0004 · §1 de docs/07-seguridad-y-despliegue/
# ══════════════════════════════════════════════════════════════════


# ── Base de datos (ACTIVAS — se consumen en este change) ──────────

# Usuario de la base de datos PostgreSQL
DB_USER=iuris

# Contraseña de la base de datos PostgreSQL
DB_PASSWORD=changeme

# URL de conexión completa (usada por el backend FastAPI / SQLAlchemy)
# Formato: postgresql://<user>:<password>@<host>:<port>/<dbname>
# En Docker el host es "db" (nombre del servicio en el compose)
DATABASE_URL=postgresql://iuris:changeme@db:5432/iuris

# Variables específicas de la imagen docker postgres:16
POSTGRES_USER=iuris
POSTGRES_PASSWORD=changeme
POSTGRES_DB=iuris


# ── Logging (ACTIVA) ──────────────────────────────────────────────

# Nivel de log del backend (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO


# ══════════════════════════════════════════════════════════════════
#  PLACEHOLDERS — changes futuros (aún no se consumen en el backend)
# ══════════════════════════════════════════════════════════════════

# ── Auth / Seguridad (change: auth) ──────────────────────────────

# Secreto para firmar los JWT (access + refresh). Mínimo 32 bytes aleatorios.
# Generar con: openssl rand -hex 32
JWT_SECRET=REEMPLAZAR_CON_SECRETO_REAL

# Algoritmo JWT (HS256 recomendado)
JWT_ALGORITHM=HS256

# Duración del access token en minutos (default: 15)
JWT_ACCESS_EXPIRE_MINUTES=15

# Duración del refresh token en días (default: 7)
JWT_REFRESH_EXPIRE_DAYS=7

# Límite de intentos de login por minuto por IP (default: "5/minute")
RATE_LIMIT=5/minute

# Bandera Secure en cookies — False en dev sin HTTPS, True en producción
COOKIE_SECURE=False

# SameSite en cookies: lax | strict | none (default: lax)
COOKIE_SAMESITE=lax


# ── Storage S3-compatible (change: storage-infra — ADR-0010) ─────
# En dev: MinIO local (levanta con Docker Compose).
# En prod: reemplazar endpoint/keys por los de Cloudflare R2; el codigo NO cambia.

# Endpoint del storage S3-compatible
STORAGE_ENDPOINT_URL=http://minio:9000

# Credenciales de acceso (MinIO en dev / R2 en prod)
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin

# Nombre del bucket (creado automaticamente por minio-init en dev)
STORAGE_BUCKET_NAME=iuris-docs

# URL publica del storage (para reemplazar hostname interno en URLs prefirmadas dev)
# En prod dejar vacio o apuntar al dominio R2 publico.
STORAGE_PUBLIC_URL=http://localhost:9000


# ── n8n / Webhooks (change: comunicaciones) ───────────────────────

# URL base del servidor n8n (usado por el backend para disparar webhooks)
# N8N_WEBHOOK_URL=http://n8n:5678/webhook

# Secreto compartido para autenticar al backend ante n8n
# N8N_SHARED_SECRET=REEMPLAZAR_CON_SECRETO_REAL


# ── Rate Limiting (ya configurado arriba en la sección Auth) ─────
# RATE_LIMIT y COOKIE_SECURE/COOKIE_SAMESITE están en la sección Auth.
